# Stockbit BYOT Configuration
# Copy this file to .env (optional — only needed for profile fallback)

# Your Stockbit username (optional fallback when token JSON lacks user info)
STOCKBIT_USERNAME=your_username

# Authentication is via BYOT — paste credentialStorage into .stockbit_token.json
# See docs/INSTALLATION.md for full setup instructions.

# Optional: in-memory GET cache TTL in milliseconds (default 30000). Set 0 to disable.
# STOCKBIT_CACHE_TTL_MS=30000